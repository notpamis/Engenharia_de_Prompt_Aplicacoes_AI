      "source": [
        "def perform_and_print_operation(title, operator_char, func, num):\n",
        "    print(f\"\\n{title.upper()}\")\n",
        "    for i in range(1, 11):\n",
        "        try:\n",
        "            result = func(num, i)\n",
        "            print(f\"{num} {operator_char} {i} = {result}\")\n",
        "        except ZeroDivisionError:\n",
        "            print(f\"{num} {operator_char} {i} = Indefinido (divisão por zero)\")\n",
        "\n",
        "num = int(input(\"Digite um número: \"))\n",
        "\n",
        "perform_and_print_operation(\"Soma\", \"+\", lambda x, y: x + y, num)\n",
        "perform_and_print_operation(\"Subtração\", \"-\", lambda x, y: x - y, num)\n",
        "perform_and_print_operation(\"Multiplicação\", \"*\", lambda x, y: x * y, num)\n",
        "perform_and_print_operation(\"Divisão\", \"/\", lambda x, y: x / y, num)"
      ],
